      "category": "health_claim",
      "severity": "block",
      "check": "Health or efficacy claims generally require RCT-grade human evidence.",
      "requiredDisclosure": null,
      "sourceUrl": "https://www.ftc.gov/business-guidance/resources/health-products-compliance-guidance"
    },
    {
      "id": "us-testimonial",
      "region": "US",
      "category": "endorsement",
      "severity": "warn",
      "check": "Testimonial claims must be substantiated as if stated directly and disclose the results a typical consumer can expect; 'results not typical' is insufficient.",
      "requiredDisclosure": "Typical-results disclosure",
      "sourceUrl": "https://www.ecfr.gov/current/title-16/chapter-I/subchapter-B/part-255"
    },
    {
      "id": "us-material-connection",
      "region": "US",
      "category": "endorsement",
      "severity": "warn",
      "check": "Material connections between an endorser and the brand must be disclosed clearly and conspicuously.",
      "requiredDisclosure": "Material-connection disclosure",
      "sourceUrl": "https://www.ecfr.gov/current/title-16/chapter-I/subchapter-B/part-255"
    },
    {
      "id": "us-comparative",
      "region": "US",
      "category": "comparative",
      "severity": "info",
