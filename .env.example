# Copy to .env (gitignored) and fill in. Never commit real keys.
# Band agents: create each in app.band.ai (type "External"), then paste its
# UUID + API key here. Key format looks like band_a_...

COORDINATOR_AGENT_ID=
COORDINATOR_API_KEY=

US_AGENT_ID=
US_API_KEY=

EU_AGENT_ID=
EU_API_KEY=

LATAM_AGENT_ID=
LATAM_API_KEY=

BRAND_AGENT_ID=
BRAND_API_KEY=

RECONCILE_AGENT_ID=
RECONCILE_API_KEY=

REMEDIATION_AGENT_ID=
REMEDIATION_API_KEY=

# Intake/relay agent for band.ai room mode (BOARD_MODE=band). Creates the room,
# adds the reviewers, posts the campaign, and observes. Handle e.g. @you/intake.
INTAKE_AGENT_ID=
INTAKE_API_KEY=

# ---- Pods topology (BOARD_TOPOLOGY=pods) on real Band ---------------------
# The pods/board/spine cast. Reuses US/EU/LATAM/REMEDIATION above; create one
# External agent per new handle in app.band.ai and paste UUID + API key here.
# Local + pods needs no Band agents (BOARD_MODE=local BOARD_TOPOLOGY=pods).
CONDUCTOR_AGENT_ID=
CONDUCTOR_API_KEY=

CLAIMS_LEAD_AGENT_ID=
CLAIMS_LEAD_API_KEY=

SCOUT_AGENT_ID=
SCOUT_API_KEY=

CLAIM_EVIDENCE_AGENT_ID=
CLAIM_EVIDENCE_API_KEY=

PRECEDENT_AGENT_ID=
PRECEDENT_API_KEY=

DISCLOSURE_AGENT_ID=
DISCLOSURE_API_KEY=

REG_LEAD_AGENT_ID=
REG_LEAD_API_KEY=

BRAND_LEAD_AGENT_ID=
BRAND_LEAD_API_KEY=

BRAND_VOICE_AGENT_ID=
BRAND_VOICE_API_KEY=

CHANNEL_AGENT_ID=
CHANNEL_API_KEY=

VISUAL_AGENT_ID=
VISUAL_API_KEY=

MEDIATOR_AGENT_ID=
MEDIATOR_API_KEY=

ADJUDICATOR_AGENT_ID=
ADJUDICATOR_API_KEY=

# Human reviewer handle (for escalation @mentions on real Band)
# HUMAN_HANDLE=@yourhandle

# Optional Band endpoint overrides (default to Band Cloud)
# BAND_REST_URL=
# BAND_WS_URL=

# ---- Board mode ----------------------------------------------------------
# 'band' (default) = real band.ai room (the product); 'local' = in-process
# transport for dev/offline. Band mode needs the agents above wired.
# BOARD_MODE=band

# ---- Orchestration topology ----------------------------------------------
# 'classic' (default) = coordinator/reconcile board; 'pods' = blackboard pods
# plus a decision spine (the redesign). Works in either BOARD_MODE.
# BOARD_TOPOLOGY=pods

# ---- Model routing -------------------------------------------------------
# 'aiml' = full AIML main path (prize target); 'dev' = cost-saver via Bedrock/Vertex/Featherless.
MODEL_MODE=dev

# AIML (main path + Nano Banana image generation)
AIML_API_KEY=

# Dev: Claude via AWS Bedrock (uses ~/.aws credentials; region required)
AWS_REGION=us-east-1
# AWS_PROFILE=

# Dev: Gemini via GCP Vertex (ADC: run `gcloud auth application-default login`)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Dev: open-model LATAM reviewer via Featherless (open-source models)
FEATHERLESS_API_KEY=
# FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Dev: OpenAI direct (optional)
# OPENAI_API_KEY=
