# Copy to .env (gitignored) and fill in. Never commit real keys.
# Band agents: create each in app.band.ai (type "External"), then paste its
# UUID + API key here. Key format looks like band_a_...

COORDINATOR_AGENT_ID=
COORDINATOR_API_KEY=

US_AGENT_ID=
US_API_KEY=

EU_AGENT_ID=
EU_API_KEY=

BRAND_AGENT_ID=
BRAND_API_KEY=

RECONCILE_AGENT_ID=
RECONCILE_API_KEY=

# Remediation is an enhancement (after the MVP); create it when we get there.
REMEDIATION_AGENT_ID=
REMEDIATION_API_KEY=

# Optional Band endpoint overrides (default to Band Cloud)
# BAND_REST_URL=
# BAND_WS_URL=

# ---- Model routing -------------------------------------------------------
# 'aiml' = full AIML, the architectural main path (prize target).
# 'dev'  = cost-saver: route to AWS Bedrock + GCP Vertex to conserve AIML credit.
# Default is 'dev' for local testing; flip to 'aiml' for the real run/submission.
MODEL_MODE=dev

# AIML (main path + Nano Banana image generation)
AIML_API_KEY=

# Dev cost-saver: Claude via AWS Bedrock (uses ~/.aws credentials; region required)
AWS_REGION=us-east-1
# AWS_PROFILE=

# Dev cost-saver: Gemini via GCP Vertex (ADC: run `gcloud auth application-default login`)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Dev cost-saver: OpenAI direct (optional)
# OPENAI_API_KEY=
